generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["plumbing_os"]
}

model Admin {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  createdAt    DateTime   @default(now())
  sessions     Session[]
  activities   Activity[]

  @@schema("plumbing_os")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@schema("plumbing_os")
}

model Lead {
  id                  String    @id @default(cuid())
  name                String
  email               String?
  phone               String?
  address             String?
  source              String?
  serviceRequested    String?
  status              String    @default("new")
  disqualifyReason    String?
  convertedCustomerId String?   @unique
  convertedCustomer   Customer? @relation("LeadConvertedCustomer", fields: [convertedCustomerId], references: [id])
  jobs                Job[]
  activities          Activity[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@schema("plumbing_os")
}

model Customer {
  id             String     @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  leadsConverted Lead[]     @relation("LeadConvertedCustomer")
  jobs           Job[]
  invoices       Invoice[]
  activities     Activity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@schema("plumbing_os")
}

model Job {
  id          String     @id @default(cuid())
  title       String
  description String?
  serviceDate DateTime?
  status      String     @default("scheduled")
  customerId  String
  leadId      String?
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices    Invoice[]
  activities  Activity[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@schema("plumbing_os")
}

model Invoice {
  id            String            @id @default(cuid())
  invoiceNumber String            @unique
  customerId    String
  jobId         String?
  issueDate     DateTime          @default(now())
  dueDate       DateTime?
  status        String            @default("draft")
  notes         String?
  subtotalCents Int               @default(0)
  taxCents      Int               @default(0)
  totalCents    Int               @default(0)
  paymentMethod String?
  paymentLink   String?
  customer      Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  job           Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  activities    Activity[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@schema("plumbing_os")
}

model InvoiceLineItem {
  id             String  @id @default(cuid())
  invoiceId      String
  description    String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@schema("plumbing_os")
}

model Activity {
  id         String    @id @default(cuid())
  type       String
  message    String
  adminId    String?
  leadId     String?
  customerId String?
  jobId      String?
  invoiceId  String?
  admin      Admin?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  job        Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@schema("plumbing_os")
}
